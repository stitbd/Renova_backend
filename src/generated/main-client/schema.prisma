generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/main-client"
}

datasource db {
  provider = "mysql"
  url      = env("MAIN_DATABASE_URL")
}

//=================SuperAdmins model==================

model SuperAdmins {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  phone    String? @unique
  password String
  isActive Boolean @default(true)

  userRoles SuperAdminUserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ================= Patient =================

enum PatientStatus {
  ACTIVE
  INACTIVE
}

model Patient {
  id String @id @default(uuid())

  referenceName    String?
  fullName         String
  mobileNumber     String        @unique
  email            String?
  password         String
  dateOfBirth      DateTime?
  age              Int?
  bloodGroup       String?
  gender           String?
  address          String?
  emergencyContact String?
  status           PatientStatus @default(ACTIVE)
  otp              String?
  otpExpiresAt     DateTime?

  outletId String?
  outlet   outlet? @relation(fields: [outletId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ================= Doctor =================

enum DoctorStatus {
  ACTIVE
  INACTIVE
}

enum DoctorOnlineStatus {
  ONLINE
  OFFLINE
}

enum DocumentType {
  LICENSE
  CERTIFICATE
  DEGREE
  NID
  OTHER
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ScheduleStatus {
  ACTIVE
  INACTIVE
}

model Doctor {
  id String @id @default(uuid())

  doctorCode String? @unique
  fullName   String
  mobile     String? @unique
  email      String  @unique
  password   String
  bmdcNumber String? @unique

  subSpecialization  String?
  qualification      String?
  experienceYears    Int?
  currentDesignation String?
  consultationFee    Decimal?           @db.Decimal(10, 2)
  status             DoctorStatus       @default(ACTIVE)
  onlineStatus       DoctorOnlineStatus @default(OFFLINE)

  outletId String?
  outlet   outlet? @relation(fields: [outletId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  specializationId String
  specialization   DoctorSpecialization @relation(fields: [specializationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  documents DoctorDocument[]
  schedules DoctorSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DoctorSpecialization {
  id      String       @id @default(uuid())
  name    String       @unique
  status  DoctorStatus @default(ACTIVE)
  doctors Doctor[]
}

model DoctorDocument {
  id                 String             @id @default(uuid())
  documentType       DocumentType
  fileUrl            String
  verificationStatus VerificationStatus @default(PENDING)

  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
}

model DoctorSchedule {
  id String @id @default(uuid())

  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  dayName      String
  startTime    String
  endTime      String
  slotDuration Int
  status       ScheduleStatus @default(ACTIVE)
}

// ================= Outlet =================

enum OutletStatus {
  ACTIVE
  INACTIVE
}

model outlet {
  id         String @id @default(uuid())
  outletCode String @unique
  outletName String
  subdomain  String @unique

  division      String
  district      String
  area          String
  address       String
  contactNumber String
  email         String @unique
  password      String

  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)

  status OutletStatus @default(ACTIVE)

  users       OutletUser[]
  outletRoles OutletRole[]

  patients Patient[]
  doctors  Doctor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("outlets")
}

model OutletUser {
  id       String @id @default(uuid())
  outletId String

  name     String
  email    String
  phone    String? @unique
  password String
  isOwner  Boolean @default(false)
  isActive Boolean @default(true)

  outlet    outlet           @relation(fields: [outletId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userRoles OutletUserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, outletId])
  @@index([outletId])
}

// ================= Outlet RBAC =================

model OutletRole {
  id String @id @default(uuid())

  outletId String
  outlet   outlet @relation(fields: [outletId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  name String

  rolePermissions OutletRolePermission[]
  userRoles       OutletUserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, outletId])
  @@index([outletId])
}

model OutletPermission {
  id String @id @default(uuid())

  key         String  @unique
  module      String
  description String?

  rolePermissions OutletRolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OutletRolePermission {
  id String @id @default(uuid())

  roleId       String
  permissionId String

  role       OutletRole       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission OutletPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model OutletUserRole {
  id String @id @default(uuid())

  outletUserId String
  roleId       String

  outletUser OutletUser @relation(fields: [outletUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role       OutletRole @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())

  @@unique([outletUserId, roleId])
  @@index([outletUserId])
  @@index([roleId])
}

// ================= Super Admin RBAC =================

model SuperAdminRole {
  id String @id @default(uuid())

  name String @unique

  rolePermissions SuperAdminRolePermission[]
  userRoles       SuperAdminUserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SuperAdminPermission {
  id String @id @default(uuid())

  key         String  @unique
  module      String
  description String?

  rolePermissions SuperAdminRolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SuperAdminRolePermission {
  id String @id @default(uuid())

  roleId       String
  permissionId String

  role       SuperAdminRole       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission SuperAdminPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model SuperAdminUserRole {
  id String @id @default(uuid())

  superAdminId String
  roleId       String

  superAdmin SuperAdmins    @relation(fields: [superAdminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role       SuperAdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())

  @@unique([superAdminId, roleId])
  @@index([superAdminId])
  @@index([roleId])
}

